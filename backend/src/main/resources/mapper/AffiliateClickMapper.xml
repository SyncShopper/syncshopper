<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.syncshopper.mapper.AffiliateClickMapper">

    <insert id="insertAffiliateClick"
            parameterType="com.syncshopper.domain.user.AffiliateClick"
            useGeneratedKeys="true"
            keyProperty="clickId">
        INSERT INTO affiliate_clicks (
            user_id,
            product_id,
            recommendation_id,
            source
        )
        VALUES (
            #{userId},
            #{productId},
            #{recommendationId},
            #{source}
        )
    </insert>

</mapper>
