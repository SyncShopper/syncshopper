<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.syncshopper.mapper.ProductMapper">

    <resultMap id="ProductResultMap" type="com.syncshopper.domain.product.Product">
        <id property="productId" column="product_id"/>
        <result property="title" column="title"/>
        <result property="brand" column="brand"/>
        <result property="categoryId" column="category_id"/>
        <result property="categoryName" column="category_name"/>
        <result property="price" column="price"/>
        <result property="imageUrl" column="image_url"/>
        <result property="affiliateUrl" column="affiliate_url"/>
        <result property="description" column="description"/>
        <result property="source" column="source"/>
        <result property="reviewCount" column="review_count"/>
        <result property="rating" column="rating"/>
        <result property="visibleYn" column="visible_yn"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="ProductColumns">
        product_id, title, brand, category_id, category_name, price, image_url,
        affiliate_url, description, source, review_count, rating, visible_yn,
        created_at, updated_at
    </sql>

    <sql id="ProductSearchWhere">
        <where>
            visible_yn = 'Y'
            <if test="categoryId != null">
                AND category_id = #{categoryId}
            </if>
            <if test="keyword != null and keyword != ''">
                AND (
                    title LIKE CONCAT('%', #{keyword}, '%')
                    OR brand LIKE CONCAT('%', #{keyword}, '%')
                    OR category_name LIKE CONCAT('%', #{keyword}, '%')
                )
            </if>
        </where>
    </sql>

    <select id="findProducts" parameterType="com.syncshopper.dto.request.ProductSearchCondition" resultMap="ProductResultMap">
        SELECT
        <include refid="ProductColumns"/>
        FROM products
        <include refid="ProductSearchWhere"/>
        <choose>
            <when test="sort == 'priceAsc'">
                ORDER BY price ASC, product_id DESC
            </when>
            <when test="sort == 'priceDesc'">
                ORDER BY price DESC, product_id DESC
            </when>
            <when test="sort == 'rating'">
                ORDER BY rating DESC, review_count DESC, product_id DESC
            </when>
            <when test="sort == 'popular'">
                ORDER BY review_count DESC, rating DESC, product_id DESC
            </when>
            <otherwise>
                ORDER BY created_at DESC, product_id DESC
            </otherwise>
        </choose>
        LIMIT #{size} OFFSET #{offset}
    </select>

    <select id="countProducts" parameterType="com.syncshopper.dto.request.ProductSearchCondition" resultType="long">
        SELECT COUNT(1)
        FROM products
        <include refid="ProductSearchWhere"/>
    </select>

    <select id="findById" parameterType="long" resultMap="ProductResultMap">
        SELECT
        <include refid="ProductColumns"/>
        FROM products
        WHERE product_id = #{productId}
          AND visible_yn = 'Y'
        LIMIT 1
    </select>

    <select id="findBestProducts" resultMap="ProductResultMap">
        SELECT
        <include refid="ProductColumns"/>
        FROM products
        WHERE visible_yn = 'Y'
        ORDER BY rating DESC, review_count DESC, product_id DESC
        LIMIT #{limit}
    </select>

    <select id="findHotProducts" resultMap="ProductResultMap">
        SELECT
        <include refid="ProductColumns"/>
        FROM products
        WHERE visible_yn = 'Y'
        ORDER BY review_count DESC, rating DESC, product_id DESC
        LIMIT #{limit}
    </select>

    <select id="findRelatedProducts" resultMap="ProductResultMap">
        SELECT
        <include refid="ProductColumns"/>
        FROM products
        WHERE visible_yn = 'Y'
          AND product_id != #{productId}
          AND category_id = #{categoryId}
        ORDER BY rating DESC, review_count DESC, product_id DESC
        LIMIT #{limit}
    </select>

</mapper>
